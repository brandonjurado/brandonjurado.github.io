{
  "homepage": "https://bjurado.com/",
  "name": "brandonjurado.github.io",
  "author": "Brandon Jurado",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.0.0",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=22.12.0 || ^20.19.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.3",
    "gsap": "^3.14.2",
    "lottie-react": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-emoji": "^1.8.1",
    "react-headroom": "^3.2.1",
    "sass": "^1.97.3"
  },
  "scripts": {
    "prepare:data": "bun run scripts/fetch-profile.mjs",
    "dev": "bun run prepare:data && vite",
    "start": "bun run dev",
    "build": "bun run prepare:data && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"./**/*.{js,jsx,ts,tsx,css,json,scss}\"",
    "check-format": "prettier -c \"./**/*.{js,jsx,ts,tsx,css,json,scss}\"",
    "test": "vitest run --passWithNoTests"
  },
  "browserslist": {
    "production": [
      ">0.3%",
      "not ie 11",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      ">0.3%",
      "not ie 11",
      "not dead",
      "not op_mini all",
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "jsdom": "^28.1.0",
    "lightningcss": "^1.31.1",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
